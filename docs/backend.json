{
  "entities": {
    "Company": {
      "title": "Company",
      "description": "Represents a business workspace/tenant.",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "tenantId": { "type": "string" },
        "name": { "type": "string" },
        "logoUrl": { "type": "string" },
        "address": { "type": "string" },
        "phone": { "type": "string" },
        "email": { "type": "string" },
        "primaryColor": { "type": "string" },
        "secondaryColor": { "type": "string" },
        "plan": { "type": "string" },
        "status": { "type": "string" },
        "createdAt": { "type": "string" },
        "createdBy": { "type": "object" }
      }
    },
    "Asset": {
      "title": "Asset",
      "description": "Hardware inventory item.",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "tenantId": { "type": "string" },
        "model": { "type": "string" },
        "serialNumber": { "type": "string" },
        "status": { "type": "string" },
        "quantity": { "type": "number" },
        "purchasePrice": { "type": "number" },
        "leasePrice": { "type": "number" },
        "createdAt": { "type": "string" },
        "purchaseDate": { "type": "string" }
      }
    },
    "Accessory": {
      "title": "Accessory",
      "description": "Generic non-serialized components.",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "tenantId": { "type": "string" },
        "name": { "type": "string" },
        "serialNumber": { "type": "string" },
        "status": { "type": "string" },
        "quantity": { "type": "number" },
        "sellingPrice": { "type": "number" }
      }
    },
    "Customer": {
      "title": "Customer",
      "description": "Client record.",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "tenantId": { "type": "string" },
        "name": { "type": "string" },
        "email": { "type": "string" },
        "phone": { "type": "string" },
        "address": { "type": "string" },
        "registrationDate": { "type": "string" }
      }
    },
    "Sale": {
      "title": "Sale",
      "description": "Point of sale transaction.",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "tenantId": { "type": "string" },
        "date": { "type": "string" },
        "amount": { "type": "number" },
        "customerId": { "type": "string" },
        "customerName": { "type": "string" },
        "paymentMethod": { "type": "string" },
        "status": { "type": "string" }
      }
    }
  },
  "auth": {
    "providers": ["password"]
  },
  "firestore": {
    "/companies/{companyId}": {
      "schema": "#/backend/entities/Company",
      "description": "Global workspace records."
    },
    "/assets/{assetId}": {
      "schema": "#/backend/entities/Asset",
      "description": "Inventory assets siloed by tenantId."
    },
    "/accessories/{accessoryId}": {
      "schema": "#/backend/entities/Accessory",
      "description": "Siloed accessory inventory."
    },
    "/customers/{customerId}": {
      "schema": "#/backend/entities/Customer",
      "description": "Customer CRM siloed by tenantId."
    },
    "/sales_transactions/{saleId}": {
      "schema": "#/backend/entities/Sale",
      "description": "POS transactions siloed by tenantId."
    },
    "/users/{userId}": {
      "schema": {
        "title": "User",
        "type": "object",
        "properties": {
          "tenantId": { "type": "string" },
          "tenantIds": { "type": "array", "items": { "type": "string" } },
          "role": { "type": "string" }
        }
      },
      "description": "User profiles with tenancy link."
    }
  }
}