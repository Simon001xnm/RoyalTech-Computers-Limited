rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    /**
     * CORE SECURITY PHILOSOPHY
     * This ruleset enforces strict tenancy isolation (Layer 2 SaaS).
     * Users can ONLY access documents where document.tenantId matches their auth.token.tenantId.
     * Platform Administrators (Super Admins) bypass tenancy checks for global support.
     */

    // --- Core Helper Functions ---

    function isSignedIn() {
      return request.auth != null;
    }

    /** Global Platform Admin check */
    function isAdmin() {
      return isSignedIn() && exists(/databases/$(database)/documents/roles_admin/$(request.auth.uid));
    }

    /** Checks if the request is correctly siloed to the user's active tenant */
    function isTenantOwner(data) {
      return isSignedIn() && (request.auth.token.tenantId == data.tenantId || isAdmin());
    }

    /** Verifies the user's own profile matching their Auth UID */
    function isSelf(userId) {
      return isSignedIn() && request.auth.uid == userId;
    }

    // --- Collection Rules ---

    /** System User Profiles */
    match /users/{userId} {
      allow get: if isSignedIn();
      allow list: if isAdmin();
      allow write: if isSelf(userId) || isAdmin();
    }

    /** Customer CRM - Siloed by tenantId */
    match /customers/{customerId} {
      allow read, list: if isSignedIn() && (isTenantOwner(resource.data) || isAdmin());
      allow create: if isSignedIn() && (request.resource.data.tenantId == request.auth.token.tenantId || isAdmin());
      allow update, delete: if isSignedIn() && (isTenantOwner(resource.data) || isAdmin());
    }

    /** Inventory Assets - Siloed by tenantId */
    match /laptop_instances/{laptopInstanceId} {
      allow read, list: if isSignedIn() && (isTenantOwner(resource.data) || isAdmin());
      allow create: if isSignedIn() && (request.resource.data.tenantId == request.auth.token.tenantId || isAdmin());
      allow update, delete: if isSignedIn() && (isTenantOwner(resource.data) || isAdmin());
    }

    /** Lease Agreements - Siloed by tenantId */
    match /lease_agreements/{leaseAgreementId} {
      allow read, list: if isSignedIn() && (isTenantOwner(resource.data) || isAdmin());
      allow create: if isSignedIn() && (request.resource.data.tenantId == request.auth.token.tenantId || isAdmin());
      allow update, delete: if isSignedIn() && (isTenantOwner(resource.data) || isAdmin());
    }

    /** Support Tickets / Repairs - Siloed by tenantId */
    match /repairs/{repairId} {
      allow read, list: if isSignedIn() && (isTenantOwner(resource.data) || isAdmin());
      allow create: if isSignedIn() && (request.resource.data.tenantId == request.auth.token.tenantId || isAdmin());
      allow update, delete: if isSignedIn() && (isTenantOwner(resource.data) || isAdmin());
    }

    /** Sales Transactions - Siloed by tenantId */
    match /sales_transactions/{salesTransactionId} {
      allow read, list: if isSignedIn() && (isTenantOwner(resource.data) || isAdmin());
      allow create: if isSignedIn() && (request.resource.data.tenantId == request.auth.token.tenantId || isAdmin());
      allow update, delete: if isAdmin(); // Transactions are immutable for standard users
    }

    /** Platform Audit Logs - Admin Only */
    match /platform_logs/{logId} {
      allow read, list: if isAdmin();
      allow create: if isSignedIn();
    }
  }
}
