rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    /**
     * CORE SECURITY PHILOSOPHY
     * This ruleset enforces strict tenancy isolation (Layer 2 SaaS).
     * Users can ONLY access documents where document.tenantId matches their active tenantId in their profile.
     */

    // --- Core Helper Functions ---

    function isSignedIn() {
      return request.auth != null;
    }

    function getUserData() {
      return get(/databases/$(database)/documents/users/$(request.auth.uid)).data;
    }

    /** Global Platform Admin check */
    function isAdmin() {
      return isSignedIn() && getUserData().role == 'super_admin';
    }

    /** Checks if the request is correctly siloed to the user's active tenant */
    function isTenantOwner(data) {
      return isSignedIn() && (getUserData().tenantId == data.tenantId || isAdmin());
    }

    /** Verifies the user's own profile matching their Auth UID */
    function isSelf(userId) {
      return isSignedIn() && request.auth.uid == userId;
    }

    // --- Collection Rules ---

    /** System User Profiles */
    match /users/{userId} {
      allow get: if isSignedIn();
      allow list: if isAdmin();
      allow write: if isSelf(userId) || isAdmin();
    }

    /** Companies / Workspaces */
    match /companies/{companyId} {
      allow read: if isSignedIn();
      allow write: if isAdmin() || (isSignedIn() && companyId == getUserData().tenantId);
    }

    /** Customer CRM - Siloed by tenantId */
    match /customers/{customerId} {
      allow read, list: if isSignedIn() && (isTenantOwner(resource.data) || isAdmin());
      allow create: if isSignedIn() && (request.resource.data.tenantId == getUserData().tenantId || isAdmin());
      allow update, delete: if isSignedIn() && (isTenantOwner(resource.data) || isAdmin());
    }

    /** Inventory Assets - Siloed by tenantId */
    match /assets/{assetId} {
      allow read, list: if isSignedIn() && (isTenantOwner(resource.data) || isAdmin());
      allow create: if isSignedIn() && (request.resource.data.tenantId == getUserData().tenantId || isAdmin());
      allow update, delete: if isSignedIn() && (isTenantOwner(resource.data) || isAdmin());
    }

    /** Sales Transactions - Siloed by tenantId */
    match /sales_transactions/{salesTransactionId} {
      allow read, list: if isSignedIn() && (isTenantOwner(resource.data) || isAdmin());
      allow create: if isSignedIn() && (request.resource.data.tenantId == getUserData().tenantId || isAdmin());
      allow update, delete: if isAdmin();
    }

    /** Accessories - Siloed by tenantId */
    match /accessories/{accessoryId} {
      allow read, list: if isSignedIn() && (isTenantOwner(resource.data) || isAdmin());
      allow create: if isSignedIn() && (request.resource.data.tenantId == getUserData().tenantId || isAdmin());
      allow update, delete: if isSignedIn() && (isTenantOwner(resource.data) || isAdmin());
    }
    
    /** Default deny for everything else */
    match /{document=**} {
      allow read, write: if isAdmin();
    }
  }
}
