rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    /**
     * GLOBAL TEST MODE
     * Allows all read and write access to all collections for all users (authenticated or not).
     * This definitively resolves "Insufficient Permissions" errors during prototyping
     * and allows the Super Admin dashboard and Nuclear Reset to function without restriction.
     */

    match /{document=**} {
      allow read, write: if true;
    }
  }
}