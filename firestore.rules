rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    /**
     * GLOBAL TEST MODE RULES
     * Allows all read and write access to all collections.
     * This is intended to resolve all "Insufficient Permissions" errors during the prototyping and setup phase.
     * 
     * WARNING: These rules are for development only. 
     * In production, these should be restricted to authenticated users with tenantId validation.
     */

    match /{document=**} {
      allow read, write: if true;
    }
  }
}