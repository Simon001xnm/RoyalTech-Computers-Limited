rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    /**
     * DEVELOPMENT / TEST MODE RULES
     * Allows all authenticated users full access to all collections.
     * This is intended to resolve "Insufficient Permissions" errors during the prototyping phase.
     */

    function isSignedIn() {
      return request.auth != null;
    }

    // Allow full access to any document for any signed-in user
    match /{document=**} {
      allow read, write: if isSignedIn();
    }

    // Explicitly allowing unauthenticated users to create their first profile document 
    // if needed during the signup process (though Auth state is usually immediate)
    match /users/{userId} {
      allow get, create, update: if true;
    }
    
    match /companies/{companyId} {
      allow read, write: if isSignedIn();
    }
  }
}