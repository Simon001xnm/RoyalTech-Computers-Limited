rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    /**
     * GLOBAL DEVELOPMENT MODE
     * Allows all read and write access to all collections for authenticated users.
     * This resolves "Insufficient Permissions" errors during prototyping.
     */

    match /{document=**} {
      allow read, write: if request.auth != null;
    }
  }
}
