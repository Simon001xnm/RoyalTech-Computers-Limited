rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    /**
     * CORE SECURITY PHILOSOPHY
     * Strict tenancy isolation. Users can ONLY access documents where 
     * document.tenantId matches their profile tenantId.
     */

    function isSignedIn() {
      return request.auth != null;
    }

    function getUserData() {
      let path = /databases/$(database)/documents/users/$(request.auth.uid);
      return exists(path) ? get(path).data : { 'role': 'user', 'tenantId': null, 'tenantIds': [] };
    }

    function isAdmin() {
      let data = getUserData();
      return isSignedIn() && (data.role == 'admin' || data.role == 'super_admin');
    }

    function isSuperAdmin() {
      return isSignedIn() && getUserData().role == 'super_admin';
    }

    function isTenantOwner(resourceData) {
      let data = getUserData();
      return isSignedIn() && (data.tenantId == resourceData.tenantId || isSuperAdmin());
    }

    // --- Collection Rules ---

    match /users/{userId} {
      allow get: if isSignedIn();
      allow list: if isSuperAdmin();
      allow create: if isSignedIn();
      allow update: if isSignedIn() && (request.auth.uid == userId || isSuperAdmin());
      allow delete: if isSuperAdmin();
    }

    match /companies/{companyId} {
      // Allow read if user belongs to this company (check both current and portfolio)
      allow read: if isSignedIn() && (
        getUserData().tenantId == companyId || 
        companyId in getUserData().tenantIds || 
        isSuperAdmin()
      );
      // Allow any signed-in user to create their first company
      allow create: if isSignedIn(); 
      allow update: if isSignedIn() && (getUserData().tenantId == companyId || isSuperAdmin());
      allow delete: if isSuperAdmin();
    }

    match /assets/{assetId} {
      allow read, list: if isSignedIn() && (isTenantOwner(resource.data) || isSuperAdmin());
      allow create: if isSignedIn() && (request.resource.data.tenantId == getUserData().tenantId || isSuperAdmin());
      allow update, delete: if isSignedIn() && (isTenantOwner(resource.data) || isSuperAdmin());
    }

    match /accessories/{accessoryId} {
      allow read, list: if isSignedIn() && (isTenantOwner(resource.data) || isSuperAdmin());
      allow create: if isSignedIn() && (request.resource.data.tenantId == getUserData().tenantId || isSuperAdmin());
      allow update, delete: if isSignedIn() && (isTenantOwner(resource.data) || isSuperAdmin());
    }

    match /customers/{customerId} {
      allow read, list: if isSignedIn() && (isTenantOwner(resource.data) || isSuperAdmin());
      allow create: if isSignedIn() && (request.resource.data.tenantId == getUserData().tenantId || isSuperAdmin());
      allow update, delete: if isSignedIn() && (isTenantOwner(resource.data) || isSuperAdmin());
    }

    match /sales_transactions/{saleId} {
      allow read, list: if isSignedIn() && (isTenantOwner(resource.data) || isSuperAdmin());
      allow create: if isSignedIn() && (request.resource.data.tenantId == getUserData().tenantId || isSuperAdmin());
      allow update, delete: if isSuperAdmin();
    }

    match /expenses/{expenseId} {
      allow read, list: if isSignedIn() && (isTenantOwner(resource.data) || isSuperAdmin());
      allow create: if isSignedIn() && (request.resource.data.tenantId == getUserData().tenantId || isSuperAdmin());
      allow update, delete: if isSignedIn() && (isTenantOwner(resource.data) || isSuperAdmin());
    }

    match /leases/{leaseId} {
      allow read, list: if isSignedIn() && (isTenantOwner(resource.data) || isSuperAdmin());
      allow create: if isSignedIn() && (request.resource.data.tenantId == getUserData().tenantId || isSuperAdmin());
      allow update, delete: if isSignedIn() && (isTenantOwner(resource.data) || isSuperAdmin());
    }
    
    match /documents/{docId} {
      allow read, list: if isSignedIn() && (isTenantOwner(resource.data) || isSuperAdmin());
      allow create: if isSignedIn() && (request.resource.data.tenantId == getUserData().tenantId || isSuperAdmin());
      allow update, delete: if isSignedIn() && (isTenantOwner(resource.data) || isSuperAdmin());
    }

    match /tickets/{ticketId} {
      allow read, list: if isSignedIn() && (isTenantOwner(resource.data) || isSuperAdmin());
      allow create: if isSignedIn() && (request.resource.data.tenantId == getUserData().tenantId || isSuperAdmin());
      allow update, delete: if isSignedIn() && (isTenantOwner(resource.data) || isSuperAdmin());
    }

    match /platform_logs/{logId} {
      allow read: if isSuperAdmin() || (isSignedIn() && resource.data.tenantId == getUserData().tenantId);
      allow create: if isSignedIn(); 
    }

    match /notifications/{notifId} {
      allow read, list: if isSignedIn() && (resource.data.tenantId == getUserData().tenantId || isSuperAdmin());
      allow create, update, delete: if isSuperAdmin();
    }

    match /messages/{msgId} {
      allow read, list: if isSignedIn() && (resource.data.tenantId == getUserData().tenantId || isSuperAdmin());
      allow create: if isSignedIn();
    }

    match /{document=**} {
      allow read, write: if isSuperAdmin();
    }
  }
}